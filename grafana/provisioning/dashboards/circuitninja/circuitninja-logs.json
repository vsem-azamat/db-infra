{
  "uid": "circuitninja-logs",
  "title": "CircuitNinja Logs",
  "tags": [
    "circuitninja",
    "logs",
    "loki"
  ],
  "timezone": "browser",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "request_id",
        "type": "textbox",
        "label": "request_id",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "CircuitNinja API/Gewen errors",
      "gridPos": {
        "x": 0,
        "y": 0,
        "h": 9,
        "w": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{container=~\".*(api|gewen).*\"} |~ \"(?i)(error|exception|failed|traceback)\""
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error log rate by container",
      "gridPos": {
        "x": 0,
        "y": 9,
        "h": 8,
        "w": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container) (count_over_time({job=\"docker\"} |~ \"(?i)(error|exception|failed|traceback)\" [$__auto]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/sec"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "All log rate by service",
      "gridPos": {
        "x": 12,
        "y": 9,
        "h": 8,
        "w": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time({job=\"docker\"} [$__auto]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/sec"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "db-infra logs",
      "gridPos": {
        "x": 0,
        "y": 17,
        "h": 8,
        "w": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_project=\"db-infra\"}"
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Request id lookup",
      "gridPos": {
        "x": 12,
        "y": 17,
        "h": 8,
        "w": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"docker\"} |= \"$request_id\""
        }
      ],
      "options": {
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ]
}
